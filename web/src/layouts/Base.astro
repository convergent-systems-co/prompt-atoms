---
const { title, description } = Astro.props;
const siteTitle = title ? `${title} · PROMPT-Atoms` : "PROMPT-Atoms";
const siteDesc = description ?? "Prompt engineering as a canonical, machine-readable, versioned library.";
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{siteTitle}</title>
    <meta name="description" content={siteDesc} />
    <link rel="canonical" href={new URL(Astro.url.pathname, Astro.site)} />
    <link rel="icon" type="image/svg+xml" href="https://brand-atoms.com/dist/brands/atom-family/1.0.0/assets/favicon.svg" />
    <link rel="preconnect" href="https://brand-atoms.com" />
    <link rel="stylesheet" href="https://brand-atoms.com/dist/brands/atom-family/1.0.0/css/tokens.css" />
    <link rel="stylesheet" href="https://brand-atoms.com/dist/brands/atom-family/1.0.0/ui/atoms-catalog.css" />
    <style is:global>
      body { min-height: 100vh; }
      .hero-mark { width: 160px; height: 160px; margin-bottom: 20px; object-fit: contain; }
      .sidenav-wordmark { width: 140px; object-fit: contain; display: block; }
      code { background: #f0f0f0; padding: 0.125rem 0.25rem; border-radius: 0.25rem; font-size: 0.9em; }
      pre { background: #f0f0f0; padding: 1rem; border-radius: 0.5rem; overflow-x: auto; }
      h1, h2, h3 { line-height: 1.2; }
    </style>
  </head>
  <body>
    <div class="shell">
      <main class="content">
        <slot />
        <footer>
          Part of the <a href="https://github.com/convergent-systems-co/atoms">atoms ecosystem</a>. Apache-2.0.
        </footer>
      </main>
      <nav class="sidenav">
        <a class="brand" href="/">
          <img src="https://brand-atoms.com/dist/brands/atom-family/1.0.0/assets/atom-family-wordmark.png" alt="ATOMS" class="sidenav-wordmark" />
        </a>
        <div class="aside-nav">
          <a href="/atoms/">Atoms</a>
          <a href="/prompts/">Compositions</a>
          <a href="/how-to-use/">How to use</a>
          <a href="/install/">Install</a>
        </div>
        <div class="aside-meta">
          <a class="meta-link" href="https://github.com/convergent-systems-co/prompt-atoms">github ↗</a>
        </div>
      </nav>
    </div>
  </body>
</html>
