# Copy to terraform.tfvars (which is .gitignored) before running plan/apply.
#
# Or set via env vars instead:
#   export TF_VAR_cloudflare_account_id=<account_id>
#
# Find the account ID in the Cloudflare dashboard URL when viewing the
# convergent-systems-co account, or via `wrangler whoami`.

cloudflare_account_id = "<convergent-systems-co account id>"

# Optional overrides — defaults already match production intent:
# project_name      = "prompt-atoms"
# production_branch = "main"
